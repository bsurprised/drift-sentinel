{
  "name": "drift-sentinel",
  "version": "1.0.0",
  "description": "Detect semantic drift between documentation and code",
  "license": "MIT",
  "author": "bsurprised",
  "repository": {
    "type": "git",
    "url": "https://github.com/bsurprised/drift-sentinel.git"
  },
  "homepage": "https://github.com/bsurprised/drift-sentinel#readme",
  "bugs": {
    "url": "https://github.com/bsurprised/drift-sentinel/issues"
  },
  "keywords": [
    "documentation",
    "drift",
    "audit",
    "cli",
    "code-quality",
    "linter",
    "markdown",
    "docs",
    "drift-detection",
    "dead-links"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "drift": "./bin/drift.js",
    "drift-sentinel": "./bin/drift.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@microsoft/tsdoc": "^0.16.0",
    "@vscode/ripgrep": "^1.17.1",
    "commander": "^14.0.3",
    "comment-parser": "^1.4.6",
    "fast-xml-parser": "^5.7.1",
    "globby": "^16.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "typescript": "^6.0.3",
    "undici": "^8.1.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
